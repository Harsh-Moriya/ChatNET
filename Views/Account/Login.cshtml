@model ChatNet.Models.User

@{
    ViewData["Title"] = "Login";
}

<link href="~/css/account.css" rel="stylesheet" />

@if(TempData["LoginError"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert" id="alert">
        @TempData["LoginError"];
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="acc-cont">
    <div class="cont">
        <div class="form-cont">
            <h4 class="acc-title">Login</h4>
            <form asp-action="Login">
                <div class="form-group">
                    <input asp-for="UserId" class="form-input" placeholder="Enter User ID" />
                    <div class="validation">
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <input asp-for="Password" class="form-input" placeholder="Enter Password" />
                    <div class="validation">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>
                <input type="submit" value="Login" class="btn btn-submit" />
                <div class="link-cont">
                    <a asp-controller="Account" asp-action="Signup">Don't have an account?</a>
                </div>
            </form>
        </div>
        <div class="img-cont">
            <img src="/images/a man who works at_5361911.png" />
        </div>
    </div>
</div>

<partial name="_Footer" />
    
@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
