@model ChatNet.Models.User

@{
    ViewData["Title"] = "Signup";
}

<link href="~/css/account.css" rel="stylesheet" />

<div class="acc-cont">
    <div class="cont">
        <div class="form-cont">
            <h4 class="acc-title">Register</h4>
            <form asp-action="Signup">
                <div class="form-group">
                    <input asp-for="UserId" class="form-input" placeholder="Enter User ID" />
                    <div class="validation">
                        <span asp-validation-for="UserId" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <input asp-for="Name" class="form-input" placeholder="Enter User Name" />
                    <div class="validation">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <input asp-for="Email" class="form-input" placeholder="Enter Email" />
                    <div class="validation">
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <input asp-for="Password" class="form-input" placeholder="Enter Password" />
                    <div class="validation">
                        <span asp-validation-for="Password" class="text-danger"></span>
                    </div>
                </div>
                <div class="form-group">
                    <input asp-for="ConfirmPassword" class="form-input" placeholder="Confirm Password" />
                    <div class="validation">
                        <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                    </div>
                </div>
                <input type="submit" value="Register" class="btn btn-submit" />
                <div class="link-cont">
                    <a asp-controller="Account" asp-action="Login" >Already have a account?</a>
                </div>
            </form>
        </div>
        <div class="img-cont">
            <img src="/images/men work at home with_5361912.png" />
        </div>
    </div>
</div>

<partial name="_Footer" />

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
